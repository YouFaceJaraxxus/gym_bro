# ─────────────────────────────────────────────────────────────────────────────
# .env.template — keys stored in Supabase secrets.
# Run scripts/pull_secrets.sh to populate .env with real values.
#
# To add a new secret:
#   1. supabase secrets set NEW_KEY=value
#   2. Add the key name here
#   3. Commit this file
# ─────────────────────────────────────────────────────────────────────────────

POSTGRES_URL=
SUPABASE_ANON_KEY=
SUPABASE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=

# Set these to target the prod DB from a local function run:
# doppler run -- supabase functions serve <fn>
APP_SUPABASE_URL=
APP_SERVICE_ROLE_KEY=
